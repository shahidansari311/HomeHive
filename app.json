{
  "expo": {
    "name": "HomeHive",
    "slug": "HomeHive",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logos/icon.png",
    "scheme": "homehive",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shahid310.homehive"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logos/andriod_foregroud.png",
        "backgroundImage": "./assets/logos/andriod_background.png",
        "monochromeImage": "./assets/logos/monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.shahid310.homehive"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logos/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
          {
            "locationWhenInUsePermission":"Allow HomeHive to access location to tag property coordinates"
          }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/logos/splash_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "@clerk/expo"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7df73bab-fdc3-4391-a8e8-7903332af315"
      }
    }
  }
}
